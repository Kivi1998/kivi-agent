# ── Secrets & local env (Wave 7 WT-K1: 防真 API key / 密码 / 内部地址被提交) ──
# 设计：所有 .env* 形式（含 .env / .env.local / .env.production）均不追踪
.env
.env.*
!.env.example
# 真实密钥/凭据常见后缀（双保险：即便误命名为 .env.bak / .secrets 等也能拦下）
*.env.bak
*.env.local
*.secrets
credentials.json
# 私钥 / 证书 / SSH key（一旦提交必须立刻 rotate）
*.pem
*.key
*.crt
id_rsa
id_ed25519
~/.ssh/

# ── Python toolchain ───────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Local runtime artifacts (Wave 6.1 引入 ~/.kama/，Wave 7 加入 ~/.kivi/) ──
.kama/
.kivi/
workspace/
!core/workspace/
!core/workspace/**
runs/
dist/
build/
*.log

# ── Editor / OS ────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
uv.lock

# ── Frontend (apps/web-chat) — Wave 3 added ────────────────────
node_modules/
package-lock.json
apps/web-chat/dist/
apps/web-chat/.vite/

# Wave 7 WT-K3: performance benchmark JSON outputs (generated at test runtime)
# Keep reports/.gitkeep to preserve the directory
reports/benchmark_*.json
reports/demo_*.json
reports/*.json
# Wave 8.2 WT-L3: real LLM E2E 报告输出（generated by KIVI_RUN_E2E=1）
reports/e2e_real/*.json
reports/e2e_real/*.md
!reports/.gitkeep
