# =====================================================================
# kivi-agent 环境配置模板（Wave 7 WT-K1 全量覆盖版）
# =====================================================================
#
# 用法：
#   1. cp .env.example .env
#   2. 按需取消注释并填写真实值（**不要提交 .env**）
#   3. Docker Compose / scripts/start.sh 默认会读 .env
#
# 安全：
#   - 真 API key / 密码 / 内部地址只能放在 .env（已被 .gitignore 拦截）
#   - 本文件（.env.example）必须只含占位符（如 sk-ant-...）或空值
#   - CI / pre-commit 已加 .env 追踪检查（scripts/pre-commit-check.sh）
#
# 分段（与计划 §三 WT-K1 对齐）：
#   [Core]        kivi-core 守护进程
#   [Logging]     日志级别 / 输出 / 格式
#   [Config]      TOML 配置文件路径
#   [LLM]         Anthropic / OpenAI 兼容 provider
#   [Embedding]   长期记忆向量检索
#   [Gateway]     Web Gateway (FastAPI)
#   [Memory]      长期记忆后端选择（local / vector / hybrid）
#   [OpenAI]      兼容 OpenAI 协议的 RAG / DB / Embedding
#   [Elasticsearch] 向量后端 (full profile 启用)
#   [Redis]       EvalEmitter Redis Streams (full profile 启用)
#   [Postgres]    DB Agent (full / test profile)
#   [RAG]         知识库 Agent
#   [Database]    数据库 Agent
#   [Health]      Gateway 探活
# =====================================================================


# ── [Core] kivi-core 守护进程 ──────────────────────────────────────
# 功能：本地 socket 监听地址；127.0.0.1 = 仅本机访问（安全默认）
KAMA_HOST=127.0.0.1
KAMA_PORT=7437


# ── [Logging] 日志 ──────────────────────────────────────────────────
# 级别：DEBUG / INFO / WARNING / ERROR
KAMA_LOG_LEVEL=INFO
# 留空 = 只输出 stderr，不写文件；填路径则同时写文件（~ 会被展开）
KAMA_LOG_FILE=~/.kivi/logs/core.log
# text = 人工可读键值对；json = 结构化（适合日志聚合 / ELK）
KAMA_LOG_FORMAT=text


# ── [Config] 显式 TOML 配置文件路径（可选）────────────────────────
# 留空 = 走优先级叠加：~/.kivi/config.toml → ./.kivi/config.toml
# KAMA_CONFIG=~/.kivi/config.toml


# ── [LLM] kivi-core 默认 LLM provider ─────────────────────────────
# 提供商：anthropic（官方）| openai_compat（OpenAI 协议兼容）
KAMA_LLM_DEFAULT_MODEL=claude-sonnet-4-6
KAMA_LLM_PROVIDER=anthropic
# openai_compat 时必填，anthropic 时可选（用于走代理/中转）
# KAMA_LLM_OPENAI_BASE_URL=https://api.openai.com/v1

# Agent 单任务最大步数（防止死循环）
KAMA_MAX_STEPS=20

# 真实 LLM API key（**不要提交真值**；本行只是格式占位）
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_BASE_URL=  # 可选：中转地址


# ── [Embedding] 长期记忆向量检索 ───────────────────────────────────
# 提供商：fake（测试）| openai（生产）
KIVI_EMBEDDING_PROVIDER=fake
# 向量维度：openai text-embedding-3-small = 1536；本项目 fake 默认 384
KIVI_EMBEDDING_DIMS=384
# OpenAI 协议兼容 embedding 模型（与 OPENAI_BASE_URL 共用 base）
KIVI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=  # 可选：自部署/中转


# ── [Gateway] Web Gateway (FastAPI) ────────────────────────────────
# 监听端口（前端 vite.config 代理指向 8000）
KIVI_GATEWAY_HOST=0.0.0.0
KIVI_GATEWAY_PORT=8000
# 跨域白名单（逗号分隔）；开发期可用 *，生产需收紧
KIVI_GATEWAY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ── [Memory] 长期记忆后端 ──────────────────────────────────────────
# local = 本地 JSONL；vector = ES 向量；hybrid = 本地优先 + 异常 fallback
KIVI_MEMORY_BACKEND=local
# 自动 fallback：vector 不可用时降级到 local（推荐 true）
KIVI_AUTO_FALLBACK=true


# ── [OpenAI] 兼容 OpenAI 协议的 RAG / DB / Embedding ──────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1


# ── [Elasticsearch] 向量后端（full profile 启用）──────────────────
# full profile 起 ES 容器（docker-compose.yml full profile），此处配客户端连接
KIVI_ES_URL=http://localhost:9200
# KIVI_ES_API_KEY=  # 留空 = 走 URL（dev 默认 xpack.security.enabled=false）
# KIVI_ES_USERNAME=
# KIVI_ES_PASSWORD=
KIVI_ES_VERIFY_CERTS=false
KIVI_ES_REQUEST_TIMEOUT_S=30


# ── [Redis] EvalEmitter Redis Streams（full profile 启用）──────────
# full profile 起 redis 容器；JSONL 后端无需此配置
KIVI_REDIS_URL=redis://localhost:6379/0
KIVI_EVAL_BACKEND=jsonl  # jsonl | redis
KIVI_EVAL_STREAM=eval:trace
KIVI_EVAL_SAMPLE_RATE=1.0


# ── [Postgres] DB Agent（full / test profile）──────────────────────
# 本地 Postgres；test profile 走 docker-compose.test.yml (kivi/kivi/kivi)
KIVI_DB_MODE=mock  # mock | sqlite | postgres
KIVI_DATABASE_URL=postgresql://kivi_test:kivi_test@localhost:5432/kivi_test


# ── [RAG] 知识库 Agent ─────────────────────────────────────────────
KIVI_RAG_MODE=mock  # mock | http
# KIVI_RAG_API_URL=http://localhost:9000/query
KIVI_RAG_TIMEOUT_S=30


# ── [Database] 数据库 Agent（共享 [Postgres]）─────────────────────
# 已在 [Postgres] 段配 KIVI_DB_MODE / KIVI_DATABASE_URL


# ── [Health] Gateway 探活参数 ──────────────────────────────────────
# 健康检查间隔 / 超时（gateway 内部用，非 health_check.sh 用）
KIVI_HEALTH_INTERVAL_S=15
KIVI_HEALTH_TIMEOUT_S=5


# ── [Chatbox Frontend] apps/web-chat（web / full profile 启用）────
# Vite 代理目标（默认指向 gateway）；一般无需改
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_WS_PROXY_TARGET=ws://127.0.0.1:8000
# 前端监听端口
VITE_DEV_PORT=5173
